{
  "_schema_meta": {
    "title": "FSA-2001 Field Mapping Schema",
    "version": "1.0",
    "description": "Maps OCR-analysed PDF form fields to applicant data values. Each entry drives a form-fill operation: text fields get a string value, checkbox/radio fields get a boolean, date fields get MM/DD/YYYY strings.",
    "conventions": {
      "SKIP": "Field exists in PDF but no data provided — leave blank",
      "FSA_USE_ONLY": "Part K — FSA staff fill only, never touch",
      "KDDRFI": "Applicant has not provided this value — must be collected before final submission",
      "data_path": "Dot-notation path into fsa2001_weeden_data_1.json. Arrays use [n] notation.",
      "fill_value": "Literal value to write when data_path is null or for checkboxes",
      "field_type": "text | checkbox | radio | date | currency | signature"
    }
  },

